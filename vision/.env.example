# =============================================================================
#  V.I.S.I.O.N. environment variables
#  Copy to `.env` and adjust. NEVER commit `.env`.
# =============================================================================

# --- General ---
VISION_ENV=development
VISION_LOG_LEVEL=INFO
VISION_LOG_DIR=./logs

# --- Models ---
VISION_MODELS_DIR=./models
VISION_ONNX_DIR=./onnx_models
VISION_DOWNLOAD_PRETRAINED=true

# SCRFD
VISION_SCRFD_MODEL=detection/scrfd_10g_bnkps.onnx
VISION_SCRFD_INPUT_SIZE=320
VISION_SCRFD_CONF_THRESH=0.5
VISION_SCRFD_NMS_THRESH=0.4

# ArcFace
VISION_ARCFACE_MODEL=recognition/arcface_r100.onnx
VISION_ARCFACE_INPUT_SIZE=112
VISION_EMBEDDING_DIM=512

# MiniFASNet
VISION_FAS_MODEL=antispoof/minifasnet_v2.onnx
VISION_FAS_INPUT_SIZE=80
VISION_FAS_THRESH=0.85

# MediaPipe
VISION_MP_MODEL_COMPLEXITY=1
VISION_MP_MAX_FACES=1
VISION_MP_REFINE_LANDMARKS=true

# Temporal
VISION_TEMPORAL_MODEL=temporal/lstm_v1.onnx
VISION_TEMPORAL_SEQ_LEN=30
VISION_TEMPORAL_STRIDE=2

# --- Recognition thresholds ---
VISION_RECOGNITION_THRESHOLD=0.45
VISION_RECOGNITION_TOP_K=5
VISION_FAISS_INDEX_TYPE=Flat              # Flat | IVFFlat | HNSW
VISION_FAISS_NLIST=64

# --- Liveness thresholds ---
VISION_LIVENESS_THRESHOLD=0.85
VISION_BLINK_MIN=1
VISION_BLINK_MAX=5
VISION_BLINK_EAR_THRESH=0.21
VISION_HEAD_YAW_RANGE=25
VISION_HEAD_PITCH_RANGE=20
VISION_EYE_MOTION_THRESH=0.3

# --- Database ---
VISION_DB_PATH=./database/vision.db
VISION_DB_BACKUP_DIR=./database/backups

# --- Backend (hybrid sync) ---
VISION_BACKEND_ENABLED=false
VISION_BACKEND_URL=https://api.vision.local
VISION_BACKEND_DEVICE_KEY=
VISION_BACKEND_TENANT_ID=

# --- Android asset mirror (CDN for ONNX downloads) ---
VISION_ANDROID_MODEL_BASE_URL=

# --- Telemetry (offline by default) ---
VISION_TELEMETRY_ENABLED=false
